rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow anyone to read data
    match /{document=**} {
      allow read: if true;
      // Only allow write if the user is logged in and their email is one of the admins
      allow write: if request.auth != null && (
        request.auth.token.email == 'litatech.support@gmail.com' ||
        request.auth.token.email == 'hasenalbanna123@gmail.com' ||
        request.auth.token.email == 'mohozafrath@gmail.com'
      );
    }
  }
}
